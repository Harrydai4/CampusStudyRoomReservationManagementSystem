# 复制本文件为 application-local.properties（同目录），填写 MySQL 密码。
# application-local.properties 已在 .gitignore 中，不会提交密码。
# 主配置 application.properties 已通过 spring.config.import 自动加载本文件。

# MySQL 连接（按本机修改）
spring.datasource.url=jdbc:mysql://localhost:3306/study_room_reservation?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
spring.datasource.username=root
spring.datasource.password=在这里填写你的MySQL密码

# 可选：JWT 与上传目录
# app.jwt.secret=请使用至少32字符的随机字符串
# app.upload.dir=uploads
